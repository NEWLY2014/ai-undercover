# ── Provider selection ──────────────────────────────────────────────
# Which backend drives the AI agents. Default: ollama (free, local).
#   ollama     → local model via Ollama (no key, no cost, offline)
#   anthropic  → Claude API (needs ANTHROPIC_API_KEY below)
#   volcengine → Volcengine Ark / Doubao (needs ARK_* below)
#   minimax    → MiniMax API / MiniMax-M2 (needs MINIMAX_* below)
UNDERCOVER_PROVIDER=ollama

# ── Ollama (local) ──────────────────────────────────────────────────
UNDERCOVER_OLLAMA_HOST=http://127.0.0.1:11434
UNDERCOVER_OLLAMA_MODEL=qwen2.5:3b

# ── Anthropic (only used when UNDERCOVER_PROVIDER=anthropic) ─────────
# Server-side only — never exposed to the browser.
ANTHROPIC_API_KEY=
# UNDERCOVER_DEFAULT_MODEL=claude-sonnet-4-6

# ── Volcengine Ark (only used when UNDERCOVER_PROVIDER=volcengine) ───
# Server-side only — never exposed to the browser.
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL is the inference endpoint id (ep-...) or an activated model name.
ARK_MODEL=

# ── MiniMax (only used when UNDERCOVER_PROVIDER=minimax) ─────────────
# Server-side only — never exposed to the browser. OpenAI-compatible API.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2

# ── Admin / security ────────────────────────────────────────────────
# The data/log dashboard is admin-only and FAIL-CLOSED. When this is unset the
# dashboard is DISABLED for everyone (the /dashboard page has no public link and
# /api/dashboard returns 404). To use it, set a strong secret here and open
# /<locale>/dashboard?key=<this value>. Required in production if you want it at all.
DASHBOARD_KEY=

# ── Provider selection ──────────────────────────────────────────────
# Which backend drives the AI agents. Default: ollama (free, local).
#   ollama    → local model via Ollama (no key, no cost, offline)
#   anthropic → Claude API (needs ANTHROPIC_API_KEY below)
UNDERCOVER_PROVIDER=ollama

# ── Ollama (local) ──────────────────────────────────────────────────
UNDERCOVER_OLLAMA_HOST=http://127.0.0.1:11434
UNDERCOVER_OLLAMA_MODEL=qwen2.5:3b

# ── Anthropic (only used when UNDERCOVER_PROVIDER=anthropic) ─────────
# Server-side only — never exposed to the browser.
ANTHROPIC_API_KEY=
# UNDERCOVER_DEFAULT_MODEL=claude-sonnet-4-6
